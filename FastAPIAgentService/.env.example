# 数据库配置
DATABASE_URL=mysql+pymysql://user:password@db:3306/oa_project

# Redis配置
REDIS_URL=redis://redis:6379/0

# Django API配置
DJANGO_API_URL=http://django-service:8000/api/v1
DJANGO_API_TOKEN=your_service_token_here

# Qwen API配置
QWEN_API_KEY=your_qwen_api_key_here

# 安全配置
SECRET_KEY=your_secret_key_here

# CORS配置
CORS_ORIGINS=["*"]
