  "components": {
    "schemas": {
      "Body_add_vector_multiple_api_vector_add_multiple_post": {
        "properties": {
          "files": {
            "items": { "type": "string", "format": "binary" },
            "type": "array",
            "title": "Files",
            "description": "要上传的文件列表，仅支持PDF和TXT格式"
          }
        },
        "type": "object",
        "required": ["files"],
        "title": "Body_add_vector_multiple_api_vector_add_multiple_post"
      },
      "Body_add_vector_single_api_vector_add_single_post": {
        "properties": { "file": { "type": "string", "format": "binary", "title": "File" } },
        "type": "object",
        "required": ["file"],
        "title": "Body_add_vector_single_api_vector_add_single_post"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": { "$ref": "#/components/schemas/ValidationError" },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ParamExtractionRequest": {
        "properties": {
          "user_input": { "type": "string", "title": "User Input" },
          "required_params": {
            "items": { "type": "string" },
            "type": "array",
            "title": "Required Params"
          }
        },
        "type": "object",
        "required": ["user_input", "required_params"],
        "title": "ParamExtractionRequest",
        "description": "参数提取测试请求模型"
      },
      "ParamExtractionResponse": {
        "properties": {
          "extracted_params": {
            "additionalProperties": true,
            "type": "object",
            "title": "Extracted Params"
          },
          "missing_params": {
            "items": { "type": "string" },
            "type": "array",
            "title": "Missing Params"
          },
          "status": { "type": "string", "title": "Status" }
        },
        "type": "object",
        "required": ["extracted_params", "missing_params", "status"],
        "title": "ParamExtractionResponse",
        "description": "参数提取测试响应模型"
      },
      "QueryRequest": {
        "properties": {
          "session_id": {
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "title": "Session Id"
          },
          "query": { "type": "string", "title": "Query" },
          "jwt_token": { "type": "string", "title": "Jwt Token" }
        },
        "type": "object",
        "required": ["query"],
        "title": "QueryRequest",
        "description": "查询请求模型"
      },
      "RAGRequest": {
        "properties": { "query": { "type": "string", "title": "Query" } },
        "type": "object",
        "required": ["query"],
        "title": "RAGRequest",
        "description": "RAG检索请求模型"
      },
      "ReorderRequest": {
        "properties": {
          "query": { "type": "string", "title": "Query" },
          "documents": { "items": { "type": "string" }, "type": "array", "title": "Documents" }
        },
        "type": "object",
        "required": ["query", "documents"],
        "title": "ReorderRequest",
        "description": "重排序请求模型"
      },
      "ReorderResponse": {
        "properties": {
          "documents": {
            "items": { "additionalProperties": true, "type": "object" },
            "type": "array",
            "title": "Documents"
          }
        },
        "type": "object",
        "required": ["documents"],
        "title": "ReorderResponse",
        "description": "重排序响应模型"
      },
      "SessionResponse": {
        "properties": {
          "session_id": { "type": "string", "title": "Session Id" },
          "history": {
            "items": {
              "prefixItems": [{ "type": "string" }, { "type": "string" }],
              "type": "array",
              "maxItems": 2,
              "minItems": 2
            },
            "type": "array",
            "title": "History"
          }
        },
        "type": "object",
        "required": ["session_id", "history"],
        "title": "SessionResponse",
        "description": "会话响应模型"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": { "anyOf": [{ "type": "string" }, { "type": "integer" }] },
            "type": "array",
            "title": "Location"
          },
          "msg": { "type": "string", "title": "Message" },
          "type": { "type": "string", "title": "Error Type" }
        },
        "type": "object",
        "required": ["loc", "msg", "type"],
        "title": "ValidationError"
      }
    },
    "securitySchemes": { "HTTPBearer": { "type": "http", "scheme": "bearer" } }
  }
}
